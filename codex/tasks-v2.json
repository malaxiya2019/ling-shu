                    "id": "8.4",
                    "name": "WeightedEvidenceGraph 合并器",
                    "desc": "多 workflow 合并算法：TF-IDF 去重、评分加权平均、冲突标记",
                    "outputs": [
                        "crates/evidence-graph/"
                    ],
                    "deps": [],
                    "status": "pending"
                },
                {
                    "id": "8.5",
                    "name": "TF-IDF 量化 (f32)",
                    "desc": "TfIdfIndex 向量从 f64 降级到 f32 存储，内存降 50%",
                    "outputs": [
                        "crates/memory-semantic/src/index.rs"
                    ],
                    "deps": [],
                    "status": "pending"
                },
                {
                    "id": "8.6",
                    "name": "RoPE 时间衰减权重",
                    "desc": "TimelineWorkflow 引入 RoPE 风格时间衰减",
                    "outputs": [
                        "crates/workflow-memory/"
                    ],
                    "deps": [],
                    "status": "pending"
