                    "desc": "WebSocket 连接管理、SSE 推送、心跳维持",
                    "outputs": [
                        "websocket/"
                    ],
                    "deps": [
                        "distributed"
                    ],
                    "status": "completed"
                },
                {
                    "id": "2.1.2",
                    "name": "流式 LLM 响应",
                    "desc": "逐 token 流式输出，支持中断/恢复",
                    "outputs": [
                        "backends/stream"
                    ],
                    "deps": [
                        "2.1.1",
                        "backends"
                    ],
                    "status": "completed"
                },
                {
                    "id": "2.1.3",
                    "name": "实时 Agent 执行推送",
                    "desc": "Agent 执行状态实时推送到 WebSocket 客户端",
                    "outputs": [
                        "runtime/stream"
