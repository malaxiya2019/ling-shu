            "version": "5.2",
            "tasks": [
                {
                    "id": "8.1",
                    "name": "ProbabilisticRouter (MoE 软路由)",
                    "desc": "将硬路由升级为 Grok-1 风格 MoE 软路由，支持多 workflow 权重路由",
