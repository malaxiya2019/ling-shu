                        "crates/memory-workflow/src/router.rs"
                    ],
                    "deps": [],
                    "status": "completed"
                },
                {
                    "id": "8.2",
                    "name": "memory-semantic 编译修复",
                    "desc": "修复多出的 `}` 导致编译错误，验证 27 个测试通过",
                    "outputs": [
                        "crates/memory-semantic/src/index.rs"
                    ],
                    "deps": [],
                    "status": "completed"
                },
                {
                    "id": "8.3",
                    "name": "MemoryRuntime 集成修复",
                    "desc": "修复路由阈值导致 3 个 runtime 测试失败的问题",
                    "outputs": [
