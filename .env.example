# =============================================================================
# 🚀 Lingshu (灵枢) Agent System — 环境变量配置模板
# =============================================================================
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 修改其中的 API Key 等敏感信息
#   3. 运行: ./start.sh
#
# 优先级: 环境变量 > .env 文件 > config/*.yaml > 代码默认值
# =============================================================================

# ─── 运行环境 ────────────────────────────────────────────────────────────────
LS_ENV=dev                          # dev | test | prod
LS_LOG_LEVEL=debug                  # trace | debug | info | warn | error
LS_LOG_FORMAT=text                  # text | json

# ─── LLM 提供商配置 (选一个即可) ─────────────────────────────────────────────
# 支持: openai | anthropic | deepseek | qwen | zhipu | baidu | groq | llmkit | mock
LLM_PROVIDER=openai

# ---- OpenAI (默认模型: gpt-4o-mini) ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1   # 可自定义转发地址

# ---- Anthropic (Claude) ----
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ---- DeepSeek (性价比极高，推荐国内使用) ----
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# ---- 阿里千问 Qwen ----
# QWEN_API_KEY=sk-xxxxxxxxxxxx
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx    # 别名，二选一

# ---- 智谱 GLM / Zhipu ----
# ZHIPU_API_KEY=xxxxxxxxxxxx

# ---- 百度文心 ----
# BAIDU_API_KEY=xxxxxxxxxxxx

# ---- Groq (免费快速推理) ----
# GROQ_API_KEY=gsk_xxxxxxxxxxxx

# ---- Google Gemini ----
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxx

# ---- llmkit (统一网关，支持 27+ 提供商) ----
# LLM_PROVIDER=llmkit
# LLMKIT_PROVIDER=anthropic           # 实际使用 llmkit 中的哪个提供商
# LLMKIT_API_KEY=lmk-xxxxxxxxxxxx

# LLM 模型覆盖
# LS_LLM_DEFAULT_MODEL=gpt-4o-mini   # 覆盖 config/*.yaml 中的 default_model

# ─── 管理面板登录 ────────────────────────────────────────────────────────────
LS_ADMIN_USER=admin                  # WebUI /admin 登录用户名
LS_ADMIN_PASSWORD=admin              # WebUI /admin 登录密码 (生产环境请修改)

# ─── JWT 密钥 (用于服务间认证) ──────────────────────────────────────────────
# 生产环境务必修改为 32+ 字符的随机字符串
# LS_SECURITY_JWT_SECRET=lingshu-dev-secret

# ─── OAuth2 登录 (可选) ──────────────────────────────────────────────────────
# LS_OAUTH2_ENABLED=false
# LS_OAUTH2_PROVIDER=google
# LS_OAUTH2_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# LS_OAUTH2_CLIENT_SECRET=GOCSPX-xxxxxxxx
# LS_OAUTH2_REDIRECT_URL=http://localhost:8080/auth/callback

# ─── 数据库 ──────────────────────────────────────────────────────────────────
# 默认使用本地 SQLite (自动创建在 ~/.local/share/lingshu/ 下)
# 如需 PostgreSQL:
# DATABASE_URL=postgres://user:pass@localhost:5432/lingshu

# ─── 消息通道 (功能开关 + 凭证) ──────────────────────────────────────────────

# Telegram Bot (需 --features telegram)
# LINGSHU_TELEGRAM_BOT_TOKEN=7234567890:AAHxxxxxxxxx

# 飞书 Bot (需 --features feishu)
# LINGSHU_FEISHU_APP_ID=cli_xxxxxxxxxxxx
# LINGSHU_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# QQ 频道 Bot (需 --features qq)
# LINGSHU_QQ_APP_ID=123456789
# LINGSHU_QQ_BOT_TOKEN=xxxxxxxxxx

# ─── 凭据管理 ────────────────────────────────────────────────────────────────
# 用于加密存储 Git Token 等敏感凭据
# LINGSHU_CREDENTIAL_MASTER_KEY=change-me-to-a-random-string

# ─── 可观测性 (可选) ─────────────────────────────────────────────────────────
# LS_OTEL_ENABLED=false              # OpenTelemetry 链路追踪
# LS_OTEL_ENDPOINT=http://localhost:4317
# LS_OTEL_SERVICE_NAME=lingshu

# LS_METRICS_ENABLED=true            # Prometheus 指标
# LS_METRICS_ADDR=0.0.0.0:9090

# LS_HEALTH_ENABLED=true             # 健康检查端点
# LS_HEALTH_ADDR=0.0.0.0:8081

# LS_LOKI_URL=http://localhost:3100  # Loki 日志聚合 (可选)

# ─── 联邦通信 (Federation) (可选) ────────────────────────────────────────────
# LS_FED_TLS_ENABLED=false
# LS_FED_TLS_CERT=/path/to/cert.pem
# LS_FED_TLS_KEY=/path/to/key.pem
# LS_FED_TLS_CA=/path/to/ca.pem

# ─── TEE 安全飞地 (可选) ─────────────────────────────────────────────────────
# LINGSHU_TEE_FORCE=none             # none | sgx | tdx (强制使用某种 TEE)

# ─── 运行时调优 ──────────────────────────────────────────────────────────────
# LS_API_KEY_RETENTION=90           # API Key 历史留存天数 (默认 90)
