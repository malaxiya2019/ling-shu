# ── Lingshu Environment ──────────────────────────────────
# Copy to .env and adjust for your environment.

# ── Runtime ──
LS_ENV=dev                          # dev | test | prod
LS_LOG_LEVEL=debug                  # trace | debug | info | warn | error
LS_LOG_FORMAT=pretty                # pretty | json
LS_SERVICE_NAME=lingshu
LS_SERVICE_VERSION=1.0.0

# ── LLM Providers ──
OPENAI_API_KEY=sk-...               # OpenAI / Groq compatible
ANTHROPIC_API_KEY=sk-ant-...        # Anthropic Claude
LS_LLM_PROVIDER=mock                # mock | openai | anthropic | groq
LS_LLM_MODEL=gpt-4o                 # default model
LS_LLM_MAX_TOKENS=4096
LS_LLM_TEMPERATURE=0.7

# ── Server ──
LS_ADDR=127.0.0.1:8080              # HTTP listen address
LS_METRICS_ADDR=0.0.0.0:9090        # Prometheus metrics endpoint

# ── Runtime Settings ──
LS_MAX_CONCURRENT_TASKS=100
LS_SESSION_TTL_SECONDS=3600

# ── Database (SQLite default) ──
LS_DATABASE_URL=lingshu.db          # SQLite path
# LS_DATABASE_URL=postgres://lingshu:lingshu_dev@localhost:5432/lingshu
LS_DATABASE_POOL_SIZE=10

# ── Storage ──
LS_STORAGE_DIR=./data/lingshu       # Local storage path

# ── Security ──
LS_JWT_SECRET=change-me-in-prod     # JWT signing secret (min 32 chars)
LS_SERVICE_KEY=                     # Ed25519 private key path (optional)

# ── OpenTelemetry (optional) ──
LS_OTEL_ENABLED=false
LS_OTEL_ENDPOINT=http://localhost:4317

# ── Plugins ──
LS_PLUGIN_DIR=./plugins

# ── Credential Vault ──
LINGSHU_CREDENTIAL_MASTER_KEY=change-me-in-production  # AES-256-GCM master key for credential encryption
